{
  "name": "mi-portafolio-moderno",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "precommit:secrets": "git diff --cached --name-only | xargs -I{} grep -lE '(AIza[0-9A-Za-z\\\\-_]{35}|AQ\\\\.[0-9A-Za-z\\\\-_]{35,}|sk-[A-Za-z0-9]{20,}|eyJ[A-Za-z0-9_-]{20,}\\\\.eyJ)' {} 2>/dev/null && echo '🚨 Posible secreto en commit detectado. Revisa tus archivos antes de subir.' && exit 1 || exit 0",
    "eval:chatbot": "npx tsx scripts/eval-chatbot.ts",
    "test": "jest",
    "test:ci": "jest --ci --coverage --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open"
  },
