# === LLM principal (Groq — gratis, sin tarjeta) ===
# Obtener en: https://console.groq.com/keys
GROQ_API_KEY=

# === Supabase (Base de Datos) ===
# Obtener en: Project Settings -> API
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# === Telegram (Notificaciones) ===
# Obtener vía @BotFather y @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Admin Panel ===
ADMIN_PASSWORD=
ADMIN_SECRET=

# === Cal.com (Agendado) ===
# URLs públicas de tus eventos
NEXT_PUBLIC_CALCOM_INTERVIEW_URL=https://cal.com/omar/entrevista-30min
NEXT_PUBLIC_CALCOM_CONSULT_URL=https://cal.com/omar/consulta-15min

# === Contacto Público ===
NEXT_PUBLIC_WHATSAPP_NUMBER=573219052878
NEXT_PUBLIC_SITE_URL=https://omarhernandez.dev

# ==========================================================================
# === FASE 27 — Multi-provider LLM failover (todas opcionales, sin tarjeta) ===
# ==========================================================================
# Cuanto más llenes, más resiliente el sistema. Mínimo recomendado:
#   GROQ_API_KEY (arriba) + OPENROUTER_API_KEY.
# Cadena de salto cuando uno se rate-limita: groq → openrouter → cerebras → cloudflare → ollama

# OpenRouter — https://openrouter.ai/keys (login con GitHub, sin tarjeta)
OPENROUTER_API_KEY=

# Cerebras Cloud — https://cloud.cerebras.ai (signup con email, sin tarjeta)
CEREBRAS_API_KEY=

# Cloudflare Workers AI — https://dash.cloudflare.com/profile/api-tokens
# Crear token con template "Workers AI". El Account ID está en el sidebar derecho del dashboard.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Ollama local — instalar con: curl -fsSL https://ollama.com/install.sh | sh && ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Override del orden de la cadena (CSV). Default: "groq,openrouter,cerebras,cloudflare,ollama"
# Ejemplo para forzar local primero: LLM_PROVIDER_CHAIN=ollama,groq,openrouter
LLM_PROVIDER_CHAIN=
